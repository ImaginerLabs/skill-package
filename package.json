{
  "name": "skill-manager",
  "version": "0.1.0",
  "description": "本地 Skill 管理工具 — 浏览、编排、同步 AI Skill 文件",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "skill-manager": "./bin/cli.cjs"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "skill",
    "manager",
    "ai",
    "workflow"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
