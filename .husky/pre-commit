#!/bin/sh
# ─── ESLint 全量检查（零警告容忍）────────────────────────────────────────────
echo "🔍 运行 ESLint 检查..."
npx eslint . --max-warnings=0
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ ESLint 检查失败，请修复上述错误后重新提交。"
  echo "   如需自动修复：npm run lint:fix"
  echo ""
  exit 1
fi

# ─── Prettier 格式检查────────────────────────────────────────────────────────
echo "🎨 运行 Prettier 格式检查..."
npx prettier --check .
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Prettier 格式检查失败，请格式化后重新提交。"
  echo "   如需自动格式化：npm run format"
  echo ""
  exit 1
fi

# ─── 检测业务文件变更，提醒同步更新 README.md 和 README.en.md ─────────────────
CHANGED=$(git diff --cached --name-only)
BUSINESS_CHANGED=$(echo "$CHANGED" | grep -E '^(src/|server/|shared/|skills/|_bmad-output/)' || true)
README_ZH_CHANGED=$(echo "$CHANGED" | grep -E '^README\.md$' || true)
README_EN_CHANGED=$(echo "$CHANGED" | grep -E '^README\.en\.md$' || true)

if [ -n "$BUSINESS_CHANGED" ] && { [ -z "$README_ZH_CHANGED" ] || [ -z "$README_EN_CHANGED" ]; }; then
  echo ""
  echo "🚫  提交被阻断：检测到业务文件变更，但 README 文档未同步更新"
  echo ""
  echo "   变更文件："
  echo "$BUSINESS_CHANGED" | sed 's/^/   - /'
  echo ""

  if [ -z "$README_ZH_CHANGED" ] && [ -z "$README_EN_CHANGED" ]; then
    echo "   ❌ README.md（中文）未更新"
    echo "   ❌ README.en.md（英文）未更新"
  elif [ -z "$README_ZH_CHANGED" ]; then
    echo "   ❌ README.md（中文）未更新"
    echo "   ✅ README.en.md（英文）已更新"
  else
    echo "   ✅ README.md（中文）已更新"
    echo "   ❌ README.en.md（英文）未更新"
  fi

  echo ""
  echo "   请检查并同步更新中英文 README（功能特性、API、技术栈等受影响章节）"
  echo "   更新后将文件加入暂存区（git add README.md README.en.md）再重新提交。"
  echo "   如确认无需更新，请手动执行：git commit --no-verify"
  echo ""
  exit 1
fi

# ─── 检测业务文件变更，提醒同步更新 project context ──────────────────────────
PROJECT_CONTEXT_CHANGED=$(echo "$CHANGED" | grep -E '^_bmad-output/project-context\.md$' || true)

if [ -n "$BUSINESS_CHANGED" ] && [ -z "$PROJECT_CONTEXT_CHANGED" ]; then
  echo ""
  echo "💡  提示：检测到业务文件变更，建议同步更新 AI 项目上下文"
  echo ""
  echo "   _bmad-output/project-context.md 记录了项目的技术规范、架构约定和 AI 代理规则。"
  echo "   若本次变更涉及技术栈、架构模式、目录结构或开发规范，请考虑更新该文件。"
  echo ""
  echo "   可使用 bmad-generate-project-context 技能重新生成，或手动编辑相关章节。"
  echo ""
fi
